{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Enable Debug Delay for Tests",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Set-Content -Path '${workspaceFolder}\\.vscode\\debug_delay_enabled.flag' -Value '7'; Write-Host 'Debug delay ENABLED - 7 seconds' -ForegroundColor Green; Write-Host 'Now run any test in CMake Test Explorer - it will wait 10 seconds for debugger' -ForegroundColor Yellow; Write-Host 'Use Disable Debug Delay task to turn off' -ForegroundColor Gray"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [],
            "windows": {
                "command": "powershell"
            }
        },
        {
            "label": "Enable Debug Delay for Tests (macOS)",
            "type": "shell",
            "command": "sh",
            "args": [
                "-c",
                "echo 7 > ${workspaceFolder}/.vscode/debug_delay_enabled.flag && echo 'Debug delay ENABLED - 7 seconds' && echo 'Now run any test in CMake Test Explorer - it will wait 10 seconds for debugger' && echo 'Use Disable Debug Delay task to turn off'"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Disable Debug Delay for Tests (macOS)",
            "type": "shell",
            "command": "sh",
            "args": [
                "-c",
                "rm -f ${workspaceFolder}/.vscode/debug_delay_enabled.flag && echo 'Debug delay DISABLED' && echo 'Tests will now run normally without delay'"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Configure Monolith",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "x64-windows-${input:monolithFlavor}",
                "-B",
                "${workspaceFolder}/.cmake-build-monolith-${input:monolithFlavor}",
                "-DINSTALL_TO_MONOLITH=ON"
            ],
            "hide": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Monolith",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/.cmake-build-monolith-${input:monolithFlavor}",
                "--config",
                "${input:monolithFlavor}"
            ],
            "hide": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Install to Monolith",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--install",
                "${workspaceFolder}/.cmake-build-monolith-${input:monolithFlavor}",
                "--config",
                "${input:monolithFlavor}",
                "--prefix",
                "${config:carbonAudio.monolithBranchRoot}/vendor/github.com/ccpgames/carbon-audio/develop"
            ],
            "dependsOn": [
                "Configure Monolith",
                "Build Monolith"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Set Perforce Branch",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "$p = '${workspaceFolder}\\.vscode\\settings.json'; $root = '${input:perforceBranchRoot}'; if (Test-Path $p) { $c = Get-Content $p -Raw } else { $c = '' }; if ([string]::IsNullOrWhiteSpace($c)) { $j = [PSCustomObject]@{} } else { $j = $c | ConvertFrom-Json }; $j | Add-Member -NotePropertyName 'carbonAudio.monolithBranchRoot' -NotePropertyValue $root -Force; $j | ConvertTo-Json -Depth 10 | Set-Content -Path $p -Encoding UTF8; Write-Host \"Perforce branch root set to: $root\" -ForegroundColor Green"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [],
            "windows": {
                "command": "powershell"
            }
        },
        {
            "label": "Clean Build Directory",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "if (Test-Path '${workspaceFolder}\\out') { Remove-Item '${workspaceFolder}\\out' -Recurse -Force; Write-Host 'Build directory cleaned successfully' -ForegroundColor Green } else { Write-Host 'No build directory to clean' -ForegroundColor Yellow }"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Disable Debug Delay for Tests",
            "type": "shell",
            "command": "powershell", 
            "args": [
                "-Command",
                "Remove-Item '${workspaceFolder}\\.vscode\\debug_delay_enabled.flag' -ErrorAction SilentlyContinue; Write-Host 'Debug delay DISABLED' -ForegroundColor Green; Write-Host 'Tests will now run normally without delay' -ForegroundColor Yellow"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [],
            "windows": {
                "command": "powershell"
            }
        },
        {
            "label": "Attach Debugger to Process",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Add-Type -AssemblyName System.Windows.Forms; [System.Windows.Forms.SendKeys]::SendWait('^+p'); Start-Sleep -Milliseconds 500; [System.Windows.Forms.SendKeys]::SendWait('Debug: Start Debugging{ENTER}')"
            ],
            "group": "test",
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "monolithFlavor",
            "type": "pickString",
            "description": "Which build flavor to install to the monolith",
            "options": [
                "internal",
                "release",
                "debug",
                "trinitydev"
            ],
            "default": "internal"
        },
        {
            "id": "perforceBranchRoot",
            "type": "promptString",
            "description": "Perforce branch root to install CarbonAudio into",
            "default": "${config:carbonAudio.monolithBranchRoot}"
        }
    ]
}